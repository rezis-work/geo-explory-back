NODE_ENV=development
API_PORT=3001
CHAT_PORT=3002
WORKER_PORT=3003
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/geo_explory

# Auth (use long random strings in production — min 32 chars)
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRES_IN=15m
